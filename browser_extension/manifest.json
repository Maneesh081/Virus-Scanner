{
  "manifest_version": 3,
  "name": "Virus Scanner",
  "version": "1.0",
  "description": "Automatically scans downloaded files for malware",
  "permissions": [
    "downloads",
    "storage",
    "notifications",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}